# ==============================================================================
# Glitch Operation (Bug Bounty Platform) - Environment Configuration Example
# Copy this file to '.env' (for local environment setup) and update values accordingly.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase Configuration
# ------------------------------------------------------------------------------
# The API URL of your Supabase project (e.g. https://xyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# The client-side publishable key for your Supabase project (typically named anon key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# The service role key for administrative operations (NEVER expose this in client-side code)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------------------------
# Nodemailer (Email Acknowledgment) Configuration
# ------------------------------------------------------------------------------
# SMTP configuration credentials for nodemailer to send automatic response emails.
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-app-password

# ------------------------------------------------------------------------------
# Google Analytics Configuration
# ------------------------------------------------------------------------------
# Google Analytics ID (e.g. G-XXXXXXX)
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# ------------------------------------------------------------------------------
# Admin & JWT Configuration
# ------------------------------------------------------------------------------
# Administrative login identifier credentials
ADMIN_ID=admin
ADMIN_SECRET=admin

# Random JWT secret key for signature verification of Admin login tokens
# You can generate one via command: openssl rand -base64 32
ADMIN_JWT_SECRET=your-random-jwt-secret-key
